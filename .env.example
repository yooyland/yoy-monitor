CHAIN_ID=1
INFURA_HTTPS=https://mainnet.infura.io/v3/your-key
INFURA_WSS=wss://mainnet.infura.io/ws/v3/your-key
ETHERSCAN_API_KEY=your-etherscan-key

# YOY ERC-20 contract (checksummed)
YOY_CONTRACT=0xf999DA2B5132eA62A158dA8A82f2265A1b1d9701

# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@host:5432/yoy_monitor_db

# Backfill sizes / polling
BACKFILL_BLOCKS=20000
MINI_BACKFILL_BLOCKS=200
ETHERSCAN_POLL_INTERVAL=60000
BATCH_SIZE=25

